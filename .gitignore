!results/
results/**/*.pt
results/**/*.pth

# Arch_Tested smoke/reproduce checkpoints (NOT the snapshot_original which IS committed)
Arch_Tested/**/checkpoints/
Arch_Tested/**/checkpoint/best_model.pt
Arch_Tested/**/__pycache__/

# Parallel-track worktrees (Simulator / Simulink_Importer)
.worktrees/

# MATLAB/Simulink build artifacts
matlab/slprj/
**/slprj/
*.slxc
*.asv
*.autosave

# HDL Coder output + Vivado litter (SP3 sintesi OOC): i numeri restano nel doc, non il VHDL generato
